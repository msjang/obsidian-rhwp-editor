{
  "name": "obsidian-rhwp-editor",
  "version": "0.2.5",
  "description": "Open, create, and edit HWP/HWPX files directly with rhwp.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs --watch",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production && node scripts/copy-wasm.mjs",
    "deploy:test-vault": "npm run build && node scripts/deploy-test-vault.mjs",
    "package:release": "npm run build && node scripts/package-release.mjs"
  },
  "keywords": [
    "hwp",
    "hwpx",
    "rhwp"
  ],
  "author": "msjang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/msjang/obsidian-rhwp-editor.git"
  },
  "bugs": {
    "url": "https://github.com/msjang/obsidian-rhwp-editor/issues"
  },
  "homepage": "https://github.com/msjang/obsidian-rhwp-editor#readme",
  "dependencies": {
    "@rhwp/core": "^0.7.15",
    "@rhwp/editor": "^0.7.15"
  },
  "devDependencies": {
    "@types/node": "^22.15.24",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.25.5",
    "jszip": "^3.10.1",
    "obsidian": "^1.8.7",
    "typescript": "^5.8.3"
  }
}
